# Surgical hoist for NestJS — required because NestJS uses runtime reflection
# and fails under pure pnpm symlinks when @nestjs/* peers aren't hoisted.
# See https://github.com/nestjs/nest/issues/13463
public-hoist-pattern[]=*nestjs*
public-hoist-pattern[]=@nestjs/*

# Resolve workspace packages as symlinks (enables workspace:* protocol).
link-workspace-packages=true
prefer-workspace-packages=true

# NestJS decorators declare optional peers we do not install; do not fail install.
strict-peer-dependencies=false

# Auto-install peer deps so Next.js / NestJS optional peers land without manual
# copy-paste of npm warnings.
auto-install-peers=true

# pnpm 10+ requires explicit allowlist for packages that run postinstall scripts.
# Prisma needs these to generate its engine binaries.
onlyBuiltDependencies[]=@prisma/client
onlyBuiltDependencies[]=@prisma/engines
onlyBuiltDependencies[]=prisma
